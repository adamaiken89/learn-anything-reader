exports[`ModuleListPage snapshot renders module list with modules 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 "><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start gap-3"><span class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-900/50 text-indigo-400 text-sm font-bold">1</span><div class="flex-1 min-w-0"><h2 class="text-base font-semibold text-white group-hover:text-indigo-400 transition-colors">Algebra Basics</h2><p class="text-xs text-gray-500 mt-1">3h</p><div class="flex flex-wrap gap-1 mt-2"><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">equations</span><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">variables</span></div></div><span class="text-gray-600 group-hover:text-indigo-400 shrink-0 mt-1">→</span></div></button><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start gap-3"><span class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-900/50 text-indigo-400 text-sm font-bold">2</span><div class="flex-1 min-w-0"><h2 class="text-base font-semibold text-white group-hover:text-indigo-400 transition-colors">Geometry</h2><p class="text-xs text-gray-500 mt-1">2h</p><div class="flex flex-wrap gap-1 mt-2"><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">shapes</span></div></div><span class="text-gray-600 group-hover:text-indigo-400 shrink-0 mt-1">→</span></div></button></div></main></div>"`;

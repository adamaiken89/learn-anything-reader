// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`ModuleListPage snapshot renders module list with modules 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"><div class="px-4 py-2 flex items-center gap-3"><div class="flex items-center gap-3 min-w-0"><button class="text-gray-400 hover:text-white transition-colors text-sm shrink-0">CourseReader</button><div class="h-4 w-px bg-gray-600"></div></div><div class="absolute left-1/2 -translate-x-1/2 z-50"><div class="relative"><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors flex items-center justify-center gap-2 min-w-[380px]"><span class="truncate">Modules</span><span class="text-xs transition-transform ">▾</span></button></div></div><div class="ml-auto flex items-center gap-1.5"><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors" title="Dashboard">📊</button><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Bookmarks</button><button class="px-3 py-1.5 text-sm bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors">Settings</button></div></div></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 "><div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"><button class="text-left bg-gray-800 hover:bg-gray-750 border rounded-xl p-5 transition-colors group cursor-pointer border-gray-700 hover:border-gray-600"><div class="flex items-start gap-3"><span class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-sm font-bold bg-indigo-900/50 text-indigo-400">1</span><div class="flex-1 min-w-0"><h2 class="text-base font-semibold text-white group-hover:text-indigo-400 transition-colors">Algebra Basics</h2><p class="text-xs text-gray-500 mt-1">3h</p><div class="flex flex-wrap gap-1 mt-2"><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">equations</span><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">variables</span></div></div><span class="text-gray-600 group-hover:text-indigo-400 shrink-0 mt-1">→</span></div></button><button class="text-left bg-gray-800 hover:bg-gray-750 border rounded-xl p-5 transition-colors group cursor-pointer border-gray-700 hover:border-gray-600"><div class="flex items-start gap-3"><span class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-sm font-bold bg-indigo-900/50 text-indigo-400">2</span><div class="flex-1 min-w-0"><h2 class="text-base font-semibold text-white group-hover:text-indigo-400 transition-colors">Geometry</h2><p class="text-xs text-gray-500 mt-1">2h</p><div class="flex flex-wrap gap-1 mt-2"><span class="text-[10px] bg-gray-700 text-gray-400 px-1.5 py-0.5 rounded">shapes</span></div></div><span class="text-gray-600 group-hover:text-indigo-400 shrink-0 mt-1">→</span></div></button></div></main></div>"`;

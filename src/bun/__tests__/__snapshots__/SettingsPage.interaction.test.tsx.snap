exports[`SettingsPage interaction shows API key input when no key configured 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 max-w-2xl mx-auto px-8 py-8 w-full"><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Gemini API Key</h3><p class="text-sm text-gray-400 mb-4">Required for the Ask AI feature. Get a free key at <a href="https://aistudio.google.com/apikey" target="_blank" class="text-indigo-400 hover:underline" rel="noreferrer">Google AI Studio</a>.</p><div class="flex gap-2"><input placeholder="Enter your Gemini API key" class="flex-1 bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500" type="password" value=""><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-indigo-600 text-white hover:bg-indigo-500 px-4 py-2 text-sm" disabled="">Save</button></div></section><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Remote Content</h3><p class="text-sm text-gray-400 mb-4">Sync course content from a GitHub repository.</p><div class="flex gap-2 mb-3"><input placeholder="https://github.com/adamaiken89/course-content" class="flex-1 bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500" type="text" value=""><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm" title="Paste from clipboard">Paste</button><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm" disabled="" title="Copy to clipboard">Copy</button><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-indigo-600 text-white hover:bg-indigo-500 px-4 py-2 text-sm" disabled="">Save URL</button></div><div class="flex items-center gap-3"><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-indigo-600 text-white hover:bg-indigo-500 px-4 py-2 text-sm" disabled="">Sync Now</button></div></section><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Reading Theme</h3><div class="grid grid-cols-2 gap-3"><button class="text-left p-3 rounded-xl border-2 transition-all border-indigo-500 bg-indigo-900/30"><div class="text-base">🌙</div><div class="text-sm font-medium mt-1">Dark</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Warm dark, easy on eyes at night</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">🖤</div><div class="text-sm font-medium mt-1">OLED</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Pure black for OLED screens</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">❄️</div><div class="text-sm font-medium mt-1">Nord</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Cool arctic tones, low strain</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">📜</div><div class="text-sm font-medium mt-1">Sepia</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Paper-like, mimics physical book</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">🪵</div><div class="text-sm font-medium mt-1">Gruvbox</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Warm retro, cozy alternative</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">☀️</div><div class="text-sm font-medium mt-1">Light</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Crisp white for bright environments</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">🔆</div><div class="text-sm font-medium mt-1">Solarized</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Scientific amber, long sessions</div></button><button class="text-left p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-base">🩷</div><div class="text-sm font-medium mt-1">Catppuccin</div><div class="text-[10px] text-gray-400 mt-0.5 leading-tight">Pastel purple, gentle contrast</div></button></div></section><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Font Size</h3><div class="flex items-center gap-3"><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm">A-</button><input min="10" max="28" class="flex-1 accent-indigo-500" type="range" value="16"><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm">A+</button><span class="text-sm text-gray-400 w-8 text-center">16</span></div></section><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Layout</h3><div class="flex gap-2"><button class="flex-1 p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-sm font-medium">Narrow</div><div class="text-[10px] text-gray-400 mt-0.5">720px centered, book-like</div></button><button class="flex-1 p-3 rounded-xl border-2 transition-all border-indigo-500 bg-indigo-900/30"><div class="text-sm font-medium">Standard</div><div class="text-[10px] text-gray-400 mt-0.5">960px, balanced width</div></button><button class="flex-1 p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500"><div class="text-sm font-medium">Wide</div><div class="text-[10px] text-gray-400 mt-0.5">Full width, max screen</div></button></div></section><section class="bg-gray-800 rounded-xl p-6 mb-6"><h3 class="text-lg font-semibold mb-4">Language</h3><div class="flex flex-wrap gap-2"><button class="px-3 py-1.5 text-xs rounded-lg border p-3 rounded-xl border-2 transition-all border-indigo-500 bg-indigo-900/30">English (US)</button><button class="px-3 py-1.5 text-xs rounded-lg border p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500">English (UK)</button><button class="px-3 py-1.5 text-xs rounded-lg border p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500">English (CA)</button><button class="px-3 py-1.5 text-xs rounded-lg border p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500">English (AU)</button><button class="px-3 py-1.5 text-xs rounded-lg border p-3 rounded-xl border-2 transition-all border-gray-700 bg-gray-800/50 hover:border-gray-500">繁體中文</button></div></section><section class="bg-gray-800 rounded-xl p-6"><h3 class="text-lg font-semibold mb-4">About</h3><p class="text-sm text-gray-400">CourseReader v1.0</p><p class="text-sm text-gray-400">macOS desktop study app with spaced repetition.</p></section></main></div>"`;


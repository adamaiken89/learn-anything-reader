// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`DashboardPage snapshots loading state 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 "><div class="text-center text-gray-500 py-12">Loading...</div></main></div>"`;

exports[`DashboardPage snapshots course stats 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 max-w-2xl mx-auto w-full"><div class="grid grid-cols-2 gap-3 mb-6"><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Modules</p><p class="text-2xl font-bold mt-1" style="color: #818cf8;">5/10<span class="text-sm font-normal text-gray-500 ml-1">(50%)</span></p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Avg Quiz Score</p><p class="text-2xl font-bold mt-1" style="color: #22c55e;">85<span class="text-sm font-normal text-gray-500 ml-1">%</span></p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Cards Due</p><p class="text-2xl font-bold mt-1" style="color: #f59e0b;">3<span class="text-sm font-normal text-gray-500 ml-1">/ 20</span></p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Day Streak</p><p class="text-2xl font-bold mt-1" style="color: #22c55e;">4<span class="text-sm font-normal text-gray-500 ml-1">days</span></p></div></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4 mb-6"><p class="text-xs font-semibold text-gray-400 mb-2">Study Time</p><div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-indigo-500 to-indigo-400" style="width: 100%;"></div></div><p class="text-xs text-gray-500 mt-1">1200 min</p></div></main></div>"`;

exports[`DashboardPage snapshots global stats 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 max-w-2xl mx-auto w-full"><div class="grid grid-cols-2 gap-3 mb-6"><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Modules</p><p class="text-2xl font-bold mt-1" style="color: #e2e8f0;">10/25</p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Day Streak</p><p class="text-2xl font-bold mt-1" style="color: #22c55e;">3<span class="text-sm font-normal text-gray-500 ml-1">days</span></p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Study Time</p><p class="text-2xl font-bold mt-1" style="color: #e2e8f0;">3000 min</p></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-[10px] text-gray-500 uppercase tracking-wider">Courses</p><p class="text-2xl font-bold mt-1" style="color: #e2e8f0;">2</p></div></div><div class="bg-gray-800 border border-gray-700 rounded-xl p-4"><p class="text-xs font-semibold text-gray-400 mb-2">Course Progress</p><div class="space-y-2"><div><div class="flex items-center justify-between text-xs mb-0.5"><span class="text-gray-300 truncate">Math</span><span class="text-gray-500 tabular-nums">5/10</span></div><div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-indigo-500 to-indigo-400" style="width: 50%;"></div></div></div><div><div class="flex items-center justify-between text-xs mb-0.5"><span class="text-gray-300 truncate">Physics</span><span class="text-gray-500 tabular-nums">5/15</span></div><div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-indigo-500 to-indigo-400" style="width: 33%;"></div></div></div></div></div></main></div>"`;

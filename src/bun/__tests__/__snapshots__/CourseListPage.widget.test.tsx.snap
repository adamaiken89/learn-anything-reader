exports[`CourseListPage snapshots content state with courses 1`] = `"<div class="h-screen flex flex-col bg-gray-900 text-gray-100 "><header class="relative z-40 bg-gray-800 border-b border-gray-700 shrink-0 min-h-7 flex flex-col"><div class="px-4 py-2 flex items-center gap-3"><div class="flex items-center gap-3 min-w-0"><button class="text-gray-400 hover:text-white transition-colors text-sm shrink-0">CourseReader</button><div class="h-4 w-px bg-gray-600"></div></div><div class="ml-auto flex items-center gap-1.5"><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm" title="Dashboard">📊</button><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm">Bookmarks</button><button class="inline-flex items-center justify-center gap-2 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed bg-gray-700 text-gray-200 hover:bg-gray-600 px-3 py-1.5 text-sm">Settings</button></div></div></header><main class="overflow-y-auto flex-1 flex flex-col px-6 py-8 "><div class="grid gap-4 sm:grid-cols-2"><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start justify-between"><div class="flex-1 min-w-0"><h2 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Mathematics 101</h2><div class="mt-1 flex flex-wrap gap-2 text-xs text-gray-400"><span class="bg-gray-700 px-2 py-0.5 rounded">beginner</span><span class="bg-gray-700 px-2 py-0.5 rounded">20h</span><span class="bg-gray-700 px-2 py-0.5 rounded">2 modules</span></div><div class="mt-3"><div class="flex items-center justify-between text-xs text-gray-400 mb-1"><span>Progress</span><span>0/2 (0%)</span></div><div class="h-1.5 bg-gray-700 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 rounded-full transition-all" style="width: 0%;"></div></div></div><ul class="mt-3 space-y-1"><li class="text-sm text-gray-400 flex items-start gap-2"><span class="text-indigo-500 mt-0.5 shrink-0">→</span><span>Understand algebra</span></li><li class="text-sm text-gray-400 flex items-start gap-2"><span class="text-indigo-500 mt-0.5 shrink-0">→</span><span>Solve equations</span></li></ul></div><span class="text-gray-600 group-hover:text-indigo-400 ml-4 mt-1 shrink-0">→</span></div></button><button class="text-left bg-gray-800 hover:bg-gray-750 border border-gray-700 rounded-xl p-5 transition-colors group cursor-pointer"><div class="flex items-start justify-between"><div class="flex-1 min-w-0"><h2 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">Physics</h2><div class="mt-1 flex flex-wrap gap-2 text-xs text-gray-400"><span class="bg-gray-700 px-2 py-0.5 rounded">intermediate</span><span class="bg-gray-700 px-2 py-0.5 rounded">30h</span><span class="bg-gray-700 px-2 py-0.5 rounded">1 modules</span></div><div class="mt-3"><div class="flex items-center justify-between text-xs text-gray-400 mb-1"><span>Progress</span><span>0/1 (0%)</span></div><div class="h-1.5 bg-gray-700 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 rounded-full transition-all" style="width: 0%;"></div></div></div></div><span class="text-gray-600 group-hover:text-indigo-400 ml-4 mt-1 shrink-0">→</span></div></button></div></main></div>"`;


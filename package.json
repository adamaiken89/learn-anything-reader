{
	"name": "coursereader",
	"version": "1.0.0",
	"type": "module",
	"description": "CourseReader - desktop study app",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
		"lint": "eslint src/ --ext .ts,.tsx",
		"lint:fix": "eslint src/ --fix --ext .ts,.tsx",
		"check": "tsc --noEmit && eslint src/ --ext .ts,.tsx && prettier --check \"src/**/*.{ts,tsx,css,json}\""
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "^1.18.1",
		"hono": "^4.12.27",
		"i18next": "^26.3.1",
		"pino": "^10.3.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-i18next": "^17.0.8",
		"react-markdown": "^10.1.0",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"eslint": "^10.5.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"happy-dom": "^20.10.6",
		"js-yaml": "^4.1.0",
		"lightningcss": "^1.32.0",
		"pino-pretty": "^13.1.3",
		"postcss": "^8.4.49",
		"prettier": "^3.8.4",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.62.0",
		"vite": "8"
	}
}
